#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpx.mjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpx.mjs" "$@"
fi
# cmd-shim-target=/Users/msuppi/aw2-amsuppi/.pnpm-store/v11/links/@/pnpm/11.6.0/be2bc59493046ab8e871eb124fa90d667ef7fc7bb68fb7ba307d11080f832b9d/node_modules/pnpm/bin/pnpx.mjs
